{
  "Video": {
    "Copy": {
      "encoder_name": ["ffmpeg"],
      "base_cmd": ["-c:v", "copy"],
      "rate_control": {},
      "options": {}
    },
    "FFV1": {
      "encoder_name": ["ffmpeg"],
      "base_cmd": ["-c:v", "ffv1"],
      "rate_control": {},
      "options": {}
    },
    "AVC (x264)": {
      "encoder_name": ["x264"],
      "base_cmd": ["-c:v", "libx264"],
      "rate_control": {
        "恒定质量 (CRF)": ["-crf", "{quality_val}"],
        "平均码率 (ABR)": ["-b:v", "{bitrate}k"],
        "2pass_1":  ["-pass", "1", "null", "NUL"],
        "2pass_2":  ["-pass", "2"]
      },
      "options": {
        "presets": ["-preset", "{preset_name}"],
        "profiles": ["-profile:v", "{profile_name}"],
        "levels": ["-level:v", "{level_val}"],
        "tune": ["-tune", "{tuning_name}"]
      }
    },
    "AVC (NVEnc)": {
      "encoder_name": ["ffmpeg"],
      "base_cmd": ["-c:v", "h264_nvenc"],
      "rate_control": {
        "恒定质量 (CRF)": ["-rc", "vbr", "-cq", "{quality_val}", "-b:v", "0" ],
        "平均码率 (ABR)": ["-rc", "cbr", "-b:v", "{bitrate}k", "-maxrate", "{bitrate}k"],
        "2pass": ["-multipass", "2"]
      },
      "options": {
        "presets": {
          "preset_fastest": ["-preset", "p1"],
          "preset_faster": ["-preset", "p2"],
          "preset_fast": ["-preset", "p3"],
          "preset_medium": ["-preset", "p4"],
          "preset_slow": ["-preset", "p5"],
          "preset_slower": ["-preset", "p6"],
          "preset_veryslow": ["-preset", "p7"]
        },
        "profiles": ["-profile:v", "{profile_name}"],
        "levels": ["-level", "{level_val}"],
        "tune": {}
      }
    },
