  "Audio": {
    "Copy": {
      "container": "",
      "base_kwargs": {"acodec": "copy"},
      "rate_control": {}
    },
    "WAV": {
      "container": "wav",
      "base_kwargs": {"acodec": "pcm_s16le"},
      "rate_control": {}
    },
    "FLAC": {
      "container": "flac",
      "base_kwargs": {"acodec": "flac"},
      "rate_control": {}
    },
    "ALAC": {
      "container": "m4a",
      "base_kwargs": {"acodec": "alac"},
      "rate_control": {}
    },
    "AAC": {
      "container": "aac",
      "base_kwargs": {"acodec": "aac"},
      "rate_control": {
        "CBR": {},
        "ABR": {"-b:a":"{bitrate}k"},
        "Quality": {"-q:a": "{quality_val}"}
      }
    },
    "MP3": {
      "container": "mp3",
      "base_kwargs": {"acodec": "libmp3lame"},
      "rate_control": {
        "CBR": {"-b:a":"{bitrate}k"},
        "ABR": {"-b:a":"{bitrate}k", "abr": "1"},
        "Quality": {"-q:a": "{quality_val}"}
      }
    },
    "Opus": {
      "container": "opus",
      "base_kwargs": {"acodec": "libopus"},
      "rate_control": {
        "CBR": {"-b:a": "{bitrate}k", "-vbr": "off"},
        "ABR": {"-b:a":"{bitrate}k", "-vbr": "on"},
        "Quality": {}
      }
    },
    "Vorbis": {
      "container": "ogg",
      "base_kwargs": {"acodec": "libvorbis"},
      "rate_control": {
        "CBR": {},
        "ABR": {},
        "Quality": {"-q:a": "{quality_val}"}
      }
    },
