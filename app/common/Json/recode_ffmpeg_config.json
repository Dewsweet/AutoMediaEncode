    },
    "ICO": {
      "container": "ico",
      "base_kwargs": {},
      "lossless": {},
      "quality": {}
    },
    "JPEG": {
      "container": "jpg",
      "base_kwargs": {},
      "rate_control": {},
      "quality": {"q:v": "{quality_val}"}
    },
    "WEBP": {
      "container": "webp",
      "base_kwargs": {"c:v": "libwebp"},
      "lossless": {"lossless": "1"},
      "quality": {"q:v": "{quality_val}"}
    },
    "AVIF": {
      "container": "avif",
      "base_kwargs": {"c:v": "libaom-av1", "still-picture": "1"},
      "lossless": {"crf": "0", "aom-params": "lossless=1"},
      "quality": {"crf": "{quality_val}"}
    },
    "JXL": {
      "container": "jxl",
      "base_kwargs": {"c:v": "libjxl"},
      "lossless": {"distance": "0.0"},
      "quality": {"distance": "{quality_val}"}
    }
  },

  "Image_filters": {
    "base_cmd": "-vf",
    "rotate": {
      "顺时针90度": "transpose=1",
      "逆时针90度": "transpose=2",
      "旋转180度": "transpose=1,transpose=1",
      "根据EXIF旋转": "transpose=0"
    },
    "flip": {
      "水平镜像": "hflip",
      "垂直镜像": "vflip"
    },
    "crop_dimension": ["crop={width}:{height}"],
    "crop_dimension_resize": ["scale={width}:{height}:force_original_aspect_ratio=increase,crop={width}:{height}"]
  },
  
  "sub_title": {
      "str": {
        "container": "srt"
      },
      "ass": {
        "container": "ass"
      },
      "lrc": {
        "container": "lrc"
      },
      "vtt": {
